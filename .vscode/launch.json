{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "machine min-win-server",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "console": "integratedTerminal",
            "program": "${workspaceFolder}/min-win-server.go",
            "args": [
                "-server-addr",
                "0.0.0.0:8443",
                "-cert-subject",
                "${input:cert-subject}",
                "-ldap-address",
                "${input:ldap-server}",
                "-ldap-users-dn",
                "${input:root-ou}",
                "-ldap-service-account-spn",
                "${input:ldap-service-account-spn}",
                "-use-ntlm=false",
            ]
        },
        {
            "name": "localhost min-win-server",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "console": "integratedTerminal",
            "program": "${workspaceFolder}/min-win-server.go",
            "args": [
                "-server-addr",
                "localhost:8443",
                "-cert-subject",
                "${input:cert-subject}",
                "-ldap-address",
                "${input:ldap-server}",
                "-ldap-users-dn",
                "${input:root-ou}",
                "-ldap-service-account-spn",
                "${input:ldap-service-account-spn}",
                "-use-ntlm=true",
            ]
        },
    ],
    "inputs": [
        {
            "type": "promptString",
            "id": "cert-subject",
            "description": "Complete or substring of certificate subject to match and use",
        },
        {
            "type": "promptString",
            "id": "ldap-server",
            "description": "LDAP server hostname:port or IP:port",
        },
        {
            "type": "promptString",
            "id": "root-ou",
            "description": "Root OU of the domain",
        },
        {
            "type": "promptString",
            "id": "ldap-service-account-spn",
            "description": "SPN of the LDAP service account",
        }
    ]
}
